# MOOSEDev configuration — copy to `.env` and adjust. Every value has a working
# default; this file documents the knobs for running/building MOOSEDev itself.
# Explicit environment variables always win over `.env`.
# NEVER put real secrets in a committed file.

# --- Core -------------------------------------------------------------------
# Where the durable store, socket, and canonical kg.nq live (relative to CWD).
# Commit <data_dir>/kg.nq; gitignore the rest (`moosedev init` sets this up).
MOOSEDEV_DATA_DIR=.moosedev

# Ontologies dir. Defaults to `ontologies/` next to the binary (release tarball)
# or the crate dir (dev), so you normally do not need to set this.
# MOOSEDEV_ONTOLOGY_DIR=./ontologies

# --- Web UI -----------------------------------------------------------------
# The graph-browsing UI binds an ephemeral loopback port by default. Set a stable
# port for a fixed URL, or 0.0.0.0:PORT for LAN access. Discoverable via
# `moosedev --status`. Set MOOSEDEV_NO_HTTP=1 to disable it.
# MOOSEDEV_HTTP_ADDR=127.0.0.1:7474
# MOOSEDEV_NO_HTTP=1

# --- Shared backend (advanced) ---------------------------------------------
# Override the Unix socket used by --serve/--connect (default <data_dir>/moosedev.sock).
# MOOSEDEV_SOCKET=/tmp/moosedev.sock
# Make --connect require an already-running backend instead of auto-spawning one.
# MOOSEDEV_NO_AUTOSPAWN=1

# --- Optional LLM assistance ------------------------------------------------
# MOOSEDev is pure-symbolic by default. Setting MOOSEDEV_LLM_BASE_URL is the
# opt-in switch that enables LLM-assisted features (e.g. the chat pipeline).
# Point it at any OpenAI-compatible endpoint — LM Studio / Ollama locally, or a
# hosted provider. Keep real API keys OUT of committed files (use your shell env).
# MOOSEDEV_LLM_BASE_URL=http://localhost:1234/v1
# MOOSEDEV_LLM_API_KEY=lm-studio
# MOOSEDEV_LLM_MODEL=your-model-id
# Assist aggressiveness 0-5 (0 = pure-symbolic; only applies when an LLM is set).
# MOOSEDEV_LLM_ASSIST_LEVEL=1

# --- Logging ----------------------------------------------------------------
# RUST_LOG=moosedev=info,rmcp=warn
