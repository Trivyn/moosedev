@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix : <https://trivyn.io/ontologies/software/architecture#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcam: <http://purl.org/dc/dcam/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix trivyn: <http://trivyn.io/ontology#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix cco: <https://www.commoncoreontologies.org/> .
@base <https://trivyn.io/ontologies/software/architecture#> .

<https://trivyn.io/ontologies/software/architecture#> a owl:Ontology ;
    rdfs:label "Domain Ontology (Clean Model)" ;
    rdfs:comment "Clean, publishable domain model with proper naming and domain ontology alignments" ;
    dcterms:created "2026-06-17T15:27:51Z"^^xsd:dateTime ;
    dcterms:modified "2026-06-17T15:27:51Z"^^xsd:dateTime ;
    dcterms:creator "Trivyn Ontology Pipeline" ;
    dcterms:publisher "Trivyn" ;
    owl:versionInfo "0.8.0" ;
    dcterms:provenance """Generated by Trivyn v0.8.0 on 2026-06-17T15:27:51Z.
Sources: unknown sources.
Domain ontology: Core Ontologies (BFO + CCO).
Domain hint: Architectural knowledge — the reasoning behind a software system's design (the "why"), captured to combat comprehension debt. The central concept is the
architectural decision: a recorded choice about a system's structure or behavior. A decision has a rationale, weighs alternatives, is motivated by
requirements and constraints, results in consequences (including accepted trade-offs), and may supersede earlier decisions as understanding evolves. Other
knowledge artifacts: constraints (restrictions the design must satisfy), lessons (generalizable insights learned in hindsight), anti-patterns (recurring
problematic structures) and patterns (their positive counterpart), and requirements (the drivers). The relationships are the heart — they encode the
reasoning chains: a decision concerns system components, is motivated by requirements/constraints, has a rationale, weighs alternatives, results in
consequences, and supersedes prior decisions; a constraint constrains components and decisions; an anti-pattern violates constraints; a lesson is learned
from decisions and anti-patterns. Every artifact is an information record about the system, carrying an author, a timestamp, and a lifecycle status
(proposed / accepted / superseded / deprecated). Rich in relationships, shallow in taxonomy. It refers to the software-engineering ontology for the system
elements that decisions and constraints are about..
Core fallback: yes.
Mid-level clustering disabled.""" .

# =============================================================================
# Annotation Property Definitions
# =============================================================================

trivyn:confidence a owl:AnnotationProperty ;
    rdfs:label "confidence score" ;
    rdfs:comment "Confidence score for automated alignments and equivalences (0.0-1.0)" ;
    rdfs:range xsd:decimal .

# =============================================================================
# Domain Ontology - Clean Publishable Model
# =============================================================================
# This ontology provides clean class/property names suitable for publication.
# Includes mid-level concepts and alignments to top-level ontologies (BFO/CCO).
# Keyless domain ontology — surrogate identifiers are confined to raw layer and bridged via owl:equivalentClass/Property axioms in mapping.ttl
# =============================================================================

# Classes
:InformationRecord a owl:Class ;
    rdfs:label "Information Record" ;
    skos:definition "A recorded piece of architectural knowledge about a system." ;
    skos:historyNote "Derived from synthesis source 'InformationRecord'" ;
    rdfs:subClassOf cco:ont00000958 {| trivyn:confidence "0.75"^^xsd:decimal ; trivyn:l0Category "record" ; trivyn:parentLabel "Information Content Entity" ; trivyn:rrfRank "1"^^xsd:integer ; skos:historyNote "Aligned to Information Content Entity via embedding similarity" ; dcterms:created "2026-06-17T15:27:51Z"^^xsd:dateTime |};
    skos:altLabel "Architectural documentation";
    skos:hiddenLabel "IR";
    skos:example "System design specification for the cloud migration project";
    skos:example "Network topology diagram for the enterprise data center";
    trivyn:labelProperty :hasTitle.

:ArchitecturalDecision a owl:Class ;
    rdfs:label "Architectural Decision" ;
    skos:definition "A recorded choice about a system's structure or behavior and its reasoning." ;
    skos:historyNote "Derived from synthesis source 'ArchitecturalDecision'" ;
    skos:altLabel "Design Decision";
    skos:altLabel "ADR";
    skos:hiddenLabel "AD";
    skos:example "Adopting a microservices architecture to improve scalability.";
    skos:example "Using a PostgreSQL database instead of a NoSQL solution for ACID compliance.".

:Rationale a owl:Class ;
    rdfs:label "Rationale" ;
    skos:definition "The reasoning behind an architectural decision." ;
    skos:historyNote "Derived from synthesis source 'Rationale'" ;
    skos:altLabel "justification";
    skos:altLabel "reasoning";
    skos:example "The decision to use a microservices architecture to improve scalability.";
    skos:example "Choosing PostgreSQL over MongoDB due to strict ACID compliance requirements.".

:Alternative a owl:Class ;
    rdfs:label "Alternative" ;
    skos:definition "A different possible choice considered during the decision process." ;
    skos:historyNote "Derived from synthesis source 'Alternative'" ;
    skos:altLabel "Option";
    skos:altLabel "Possibility";
    skos:example "A different vendor for the same raw material";
    skos:example "A secondary route for a delivery path".

:Consequence a owl:Class ;
    rdfs:label "Consequence" ;
    skos:definition "The outcome of a decision, including accepted trade-offs." ;
    skos:historyNote "Derived from synthesis source 'Consequence'" ;
    skos:altLabel "Outcome";
    skos:altLabel "Aftermath";
    skos:altLabel "Result";
    skos:example "Increased operational costs due to a policy change";
    skos:example "Improved customer satisfaction following a service upgrade".

:Constraint a owl:Class ;
    rdfs:label "Constraint" ;
    skos:definition "A restriction that the design must satisfy." ;
    skos:historyNote "Derived from synthesis source 'Constraint'" ;
    skos:altLabel "Restriction";
    skos:altLabel "Limitation";
    skos:example "Maximum load capacity of a structural beam";
    skos:example "Operating temperature range for a component".

:Requirement a owl:Class ;
    rdfs:label "Requirement" ;
    skos:definition "A driver that motivates an architectural decision." ;
    skos:historyNote "Derived from synthesis source 'Requirement'" ;
    skos:altLabel "Specification";
    skos:altLabel "Necessity";
    skos:hiddenLabel "REQ";
    skos:example "The system must support up to 10,000 concurrent users.";
    skos:example "Data must be encrypted using AES-256 at rest.".

:Lesson a owl:Class ;
    rdfs:label "Lesson" ;
    skos:definition "A generalizable insight learned in hindsight." ;
    skos:historyNote "Derived from synthesis source 'Lesson'" ;
    skos:altLabel "Learning point";
    skos:altLabel "Takeaway";
    skos:example "Always verify backup integrity before decommissioning hardware.";
    skos:example "Early stakeholder engagement prevents scope creep in development.".

:Pattern a owl:Class ;
    rdfs:label "Pattern" ;
    skos:definition "A positive, reusable architectural structure or solution." ;
    skos:historyNote "Derived from synthesis source 'Pattern'" ;
    skos:altLabel "Design Pattern";
    skos:altLabel "Architectural Pattern";
    skos:example "Microservices Architecture";
    skos:example "Singleton";
    skos:example "Observer Pattern".

:AntiPattern a owl:Class ;
    rdfs:label "Anti Pattern" ;
    skos:definition "A recurring problematic architectural structure." ;
    skos:historyNote "Derived from synthesis source 'AntiPattern'" ;
    skos:altLabel "Design flaw";
    skos:altLabel "Bad practice";
    skos:example "God Object";
    skos:example "Spaghetti Code";
    skos:example "Hard-coded configuration".

:SystemComponent a owl:Class ;
    rdfs:label "System Component" ;
    skos:definition "An element of the software system that decisions and constraints act upon." ;
    trivyn:labelProperty :hasComponentName ;
    skos:historyNote "Derived from synthesis source 'SystemComponent'" ;
    skos:altLabel "Software module";
    skos:altLabel "System element";
    skos:hiddenLabel "SC";
    skos:example "Authentication Service";
    skos:example "Database Connector";
    skos:example "User Interface Layer".

# Datatype Properties
:hasAuthor a owl:DatatypeProperty ;
    rdfs:label "has author" ;
    rdfs:domain :InformationRecord ;
    rdfs:range xsd:string ;
    skos:historyNote "Mapped from synthesis field 'InformationRecord.author'" ;
    rdfs:subPropertyOf cco:ont00001765 {| trivyn:confidence "0.85"^^xsd:decimal ; trivyn:parentLabel "has text value" ; skos:historyNote "Aligned to has text value via embedding similarity" ; dcterms:created "2026-06-17T15:27:51Z"^^xsd:dateTime |};
    sh:minCount "1"^^xsd:integer;
    skos:definition "Records the author of an information record as a string value.";
    skos:altLabel "has author".

:hasComponentName a owl:DatatypeProperty ;
    rdfs:label "has component name" ;
    rdfs:domain :SystemComponent ;
    rdfs:range xsd:string ;
    skos:historyNote "Mapped from synthesis field 'SystemComponent.componentName'" ;
    sh:minCount "1"^^xsd:integer;
    skos:definition "Records the name of a system component.";
    skos:altLabel "has component name".

:coversPath a owl:DatatypeProperty ;
    rdfs:label "covers path" ;
    rdfs:domain :SystemComponent ;
    rdfs:range xsd:string ;
    skos:definition "Repo-relative path prefix covered by a system component; a trailing slash denotes a directory prefix, and the property may be multi-valued.";
    skos:altLabel "covers path".

:hasLifecycleStatus a owl:DatatypeProperty ;
    rdfs:label "has lifecycle status" ;
    rdfs:domain :InformationRecord ;
    rdfs:range xsd:string ;
    skos:historyNote "Mapped from synthesis field 'InformationRecord.lifecycleStatus'" ;
    rdfs:subPropertyOf cco:ont00001765 {| trivyn:confidence "0.85"^^xsd:decimal ; trivyn:parentLabel "has text value" ; skos:historyNote "Aligned to has text value via embedding similarity" ; dcterms:created "2026-06-17T15:27:51Z"^^xsd:dateTime |};
    sh:minCount "1"^^xsd:integer;
    skos:definition "Records the lifecycle status of an information record.";
    skos:altLabel "has lifecycle status".

:hasTimestamp a owl:DatatypeProperty ;
    rdfs:label "has timestamp" ;
    rdfs:domain :InformationRecord ;
    rdfs:range xsd:dateTime ;
    skos:historyNote "Mapped from synthesis field 'InformationRecord.timestamp'" ;
    rdfs:subPropertyOf cco:ont00001767 {| trivyn:confidence "0.85"^^xsd:decimal ; trivyn:parentLabel "has datetime value" ; skos:historyNote "Aligned to has datetime value via embedding similarity" ; dcterms:created "2026-06-17T15:27:51Z"^^xsd:dateTime |};
    sh:minCount "1"^^xsd:integer;
    skos:definition "Records the temporal occurrence of an information record.";
    skos:altLabel "has timestamp".

:hasTitle a owl:DatatypeProperty ;
    skos:prefLabel "has title"@en ;
    rdfs:label "has title" ;
    rdfs:domain :InformationRecord ;
    rdfs:range xsd:string ;
    prov:wasGeneratedBy trivyn:UserAuthoringActivity .

:hasDescription a owl:DatatypeProperty ;
    skos:prefLabel "has description"@en ;
    rdfs:label "has description" ;
    rdfs:domain :InformationRecord ;
    rdfs:range xsd:string ;
    prov:wasGeneratedBy trivyn:UserAuthoringActivity .

# =============================================================================
# End of Domain Ontology
# =============================================================================

# Intra-domain taxonomy (synthesis subClassOf hierarchy).
:ArchitecturalDecision rdfs:subClassOf :InformationRecord .
:Rationale rdfs:subClassOf :InformationRecord .
:Alternative rdfs:subClassOf :InformationRecord .
:Consequence rdfs:subClassOf :InformationRecord .
:Constraint rdfs:subClassOf :InformationRecord .
:Requirement rdfs:subClassOf :InformationRecord .
:Lesson rdfs:subClassOf :InformationRecord .
:Pattern rdfs:subClassOf :InformationRecord .
:AntiPattern rdfs:subClassOf :InformationRecord .

# Domain relations (synthesis taxonomy).
:concerns a owl:ObjectProperty ;
    rdfs:label "concerns" ;
    rdfs:domain :InformationRecord ;
    dcam:rangeIncludes :SystemComponent, <https://trivyn.io/ontologies/software/code#CodeEntity> ;
    skos:definition "Relates an information record to the system component or code entity it affects or describes. Range widened to code entities 2026-07-08 (v2 intent links, AD 7079634f).".
:isMotivatedBy a owl:ObjectProperty ;
    rdfs:label "isMotivatedBy" ;
    rdfs:domain :ArchitecturalDecision ;
    dcam:rangeIncludes :Requirement, :Constraint ;
    skos:definition "Relates an architectural decision to the reason or driver behind it.";
    skos:altLabel "is motivated by".
:hasRationale a owl:ObjectProperty ;
    rdfs:label "hasRationale" ;
    rdfs:range :Rationale ;
    rdfs:subPropertyOf obo:BFO_0000176 {| trivyn:confidence "0.70"^^xsd:decimal ; trivyn:parentLabel "continuant part of" ; trivyn:rrfRank "2"^^xsd:integer ; skos:historyNote "Aligned to continuant part of via embedding similarity" ; dcterms:created "2026-06-17T15:28:08Z"^^xsd:dateTime |};
    skos:definition "Relates an architectural decision to its underlying reasoning.";
    skos:altLabel "has rationale";
    rdfs:domain :InformationRecord.
:weighs a owl:ObjectProperty ;
    rdfs:label "weighs" ;
    rdfs:domain :ArchitecturalDecision ;
    rdfs:range :Alternative ;
    skos:definition "Relates an architectural decision to the alternative it evaluates.".
:resultsIn a owl:ObjectProperty ;
    rdfs:label "resultsIn" ;
    rdfs:domain :ArchitecturalDecision ;
    rdfs:range :Consequence ;
    skos:definition "Relates an architectural decision to its resulting consequence.";
    skos:altLabel "leads to";
    skos:altLabel "produces";
    skos:altLabel "results in".
:supersedes a owl:ObjectProperty ;
    rdfs:label "supersedes" ;
    skos:definition "Relates an architectural decision to the one it replaces.";
    rdfs:domain :InformationRecord;
    rdfs:range :InformationRecord.
:constrains a owl:ObjectProperty ;
    rdfs:label "constrains" ;
    rdfs:domain :Constraint ;
    dcam:rangeIncludes :SystemComponent, :ArchitecturalDecision, <https://trivyn.io/ontologies/software/code#CodeEntity> ;
    skos:definition "Relates a constraint to the design it restricts. Range widened to code entities 2026-07-08 (v2 intent links, AD 7079634f).".
:learnedFrom a owl:ObjectProperty ;
    rdfs:label "learnedFrom" ;
    rdfs:domain :Lesson ;
    dcam:rangeIncludes :ArchitecturalDecision, :AntiPattern ;
    skos:definition "Relates a lesson to the source from which it was acquired.";
    skos:altLabel "learned from".
:violates a owl:ObjectProperty ;
    rdfs:label "violates" ;
    dcam:domainIncludes :AntiPattern, <https://trivyn.io/ontologies/software/code#CodeEntity> ;
    rdfs:range :Constraint ;
    skos:definition "Relates an AntiPattern or code entity to the Constraint it fails to satisfy. Domain widened to code entities 2026-07-08 (v2 intent links, AD 7079634f).".
:motivates a owl:ObjectProperty ;
      rdfs:label "motivates" ;
      owl:inverseOf :isMotivatedBy ;
      dcam:domainIncludes :Requirement, :Constraint ;
      rdfs:range :ArchitecturalDecision ;
      skos:definition "Relates a requirement or constraint to the architectural decision it drives." ;
      skos:altLabel "drives" .
:isConcernedBy a owl:ObjectProperty ;
      rdfs:label "is concerned by" ;
      owl:inverseOf :concerns ;
      dcam:domainIncludes :SystemComponent, <https://trivyn.io/ontologies/software/code#CodeEntity> ;
      rdfs:range :InformationRecord ;
      skos:definition "Relates a system component or code entity to an information record that affects or describes it." ;
      skos:altLabel "is affected by" .

:isRationaleFor a owl:ObjectProperty ;
      rdfs:label "is rationale for" ;
      owl:inverseOf :hasRationale ;
      rdfs:domain :Rationale ;
      rdfs:range :InformationRecord ;
      skos:definition "Relates a rationale to the information record whose reasoning it provides." ;
      skos:altLabel "justifies" .

:isWeighedBy a owl:ObjectProperty ;
      rdfs:label "is weighed by" ;
      owl:inverseOf :weighs ;
      rdfs:domain :Alternative ;
      rdfs:range :ArchitecturalDecision ;
      skos:definition "Relates an alternative to the architectural decision that evaluates it." ;
      skos:altLabel "is considered by" .

:resultsFrom a owl:ObjectProperty ;
      rdfs:label "results from" ;
      owl:inverseOf :resultsIn ;
      rdfs:domain :Consequence ;
      rdfs:range :ArchitecturalDecision ;
      skos:definition "Relates a consequence to the architectural decision that produced it." ;
      skos:altLabel "is consequence of" .

:isSupersededBy a owl:ObjectProperty ;
      rdfs:label "is superseded by" ;
      owl:inverseOf :supersedes ;
      rdfs:domain :InformationRecord ;
      rdfs:range :InformationRecord ;
      skos:definition "Relates an information record to the record that replaces it." .

:isConstrainedBy a owl:ObjectProperty ;
      rdfs:label "is constrained by" ;
      owl:inverseOf :constrains ;
      dcam:domainIncludes :SystemComponent, :ArchitecturalDecision, <https://trivyn.io/ontologies/software/code#CodeEntity> ;
      rdfs:range :Constraint ;
      skos:definition "Relates a system component, architectural decision, or code entity to a constraint that restricts it." .

:yieldsLesson a owl:ObjectProperty ;
      rdfs:label "yields lesson" ;
      owl:inverseOf :learnedFrom ;
      dcam:domainIncludes :ArchitecturalDecision, :AntiPattern ;
      rdfs:range :Lesson ;
      skos:definition "Relates an architectural decision or anti-pattern to a lesson learned from it." ;
      skos:altLabel "is lesson source for" .

:isViolatedBy a owl:ObjectProperty ;
      rdfs:label "is violated by" ;
      owl:inverseOf :violates ;
      rdfs:domain :Constraint ;
      dcam:rangeIncludes :AntiPattern, <https://trivyn.io/ontologies/software/code#CodeEntity> ;
      skos:definition "Relates a constraint to an anti-pattern or code entity that fails to satisfy it." .

# Competency questions this ontology was built to answer (synthesis).
<https://trivyn.io/ontologies/software/architecture#>
    <https://trivyn.io/ontologies/toekg#satisfiesCompetencyQuestion> "Which architectural decision supersedes a previous one?",
        "What constraints are currently being violated by an anti-pattern?",
        "Which requirements motivated a specific architectural decision?",
        "What are the consequences and trade-offs of this decision?",
        "Which components are affected by a specific constraint?",
        "What lessons were learned from previous architectural decisions or anti-patterns?" .

# Design patterns that grounded this synthesis (TOEKG Tier-1 retrieval).
<https://trivyn.io/ontologies/software/architecture#>
    <https://trivyn.io/ontologies/toekg#derivedFromPattern> <https://trivyn.io/ontologies/toekg#P-information-artifact>,
        <https://trivyn.io/ontologies/toekg#G-determined-attribute-belongs-to-determinant>,
        <https://trivyn.io/ontologies/toekg#G-information-content-entity>,
        <https://trivyn.io/ontologies/toekg#G-metadata-and-annotation-not-entity> .

