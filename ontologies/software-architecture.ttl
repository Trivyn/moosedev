<https://trivyn.io/ontologies/software/architecture#> <http://www.w3.org/ns/prov#wasGeneratedBy> <https://trivyn.io/ontologies/software/architecture#synthesis-activity> .
<https://trivyn.io/ontologies/software/architecture#synthesis-activity> a <http://www.w3.org/ns/prov#Activity> ;
    <https://trivyn.io/ontologies/toekg#generatedWithModel> "gemma-4-26b-a4b-it-mlx" ;
    <https://trivyn.io/ontologies/toekg#descriptionHash> "sha256:d6463dacb859ba1411bd2cf249f0caa88de203a1d3647362896f2e422a7f5553" ;
    <https://trivyn.io/ontologies/toekg#baseIri> "https://trivyn.io/ontologies/software/architecture/" .

# Referenceable ontology bridges (MOOSE).
:SystemComponent rdfs:subClassOf <https://trivyn.io/ontologies/software/engineering#Component> {| trivyn:confidence "0.70"^^xsd:decimal ; skos:historyNote "Specialized under https://trivyn.io/ontologies/software/engineering via MOOSE (subclass)" ; trivyn:rrfRank "2"^^xsd:integer |} .
:hasComponentName owl:equivalentProperty <https://trivyn.io/ontologies/software/engineering#hasComponentName> {| trivyn:confidence "0.95"^^xsd:decimal ; skos:historyNote "Reused from https://trivyn.io/ontologies/software/engineering via MOOSE (equivalent property)" |} .

# Imported ontologies used by referenceable bridges.
<https://trivyn.io/ontologies/software/architecture#> owl:imports <https://trivyn.io/ontologies/software/engineering#> .
